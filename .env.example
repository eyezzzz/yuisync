# Frontend public vars only
# IMPORTANT: never place service_role key in any VITE_ variable.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_API_URL=/api
# UUID publico do tenant de homologacao, usado apenas para sinalizacao da UI.
VITE_TEST_TENANT_ID=

# Server-only vars
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

OPENAI_API_KEY=your-server-only-openai-key
OPENAI_MODEL=gpt-4o-mini-2024-07-18
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe-2025-12-15
OPENAI_VISION_MODEL=gpt-4o-mini-2024-07-18
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=1

# Product image search (server-side only, Google Programmable Search Engine)
GOOGLE_IMAGE_SEARCH_API_KEY=
GOOGLE_IMAGE_SEARCH_CX=

# Focus NFe (server-side only)
FOCUS_NFE_TOKEN=
FOCUS_NFE_PROD_URL=https://api.focusnfe.com.br
FOCUS_NFE_HOMOLOG_URL=https://homologacao.focusnfe.com.br
FOCUS_NFE_WEBHOOK_TOKEN=
FOCUS_NFE_TIMEOUT_MS=30000

# WhatsApp Cloud API (server-side only)
# Prefer tenant_bot_channels for production multi-tenant setups.
# WHATSAPP_TENANT_ID is only an emergency fallback; the backend now auto-picks
# a single active tenant or a single tenant in the project when possible.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_REPLY_DEBOUNCE_MS=1000
# Required when more than one tenant exists in Supabase.
WHATSAPP_TENANT_ID=
WHATSAPP_MODULE_ID=petshop

# API server
API_PORT=3090
API_ALLOWED_ORIGINS=http://localhost:3080
# UUID do unico tenant onde resets de homologacao sao permitidos.
MAINTENANCE_TEST_TENANT_ID=

# Credenciais exclusivas para teste automatizado de RLS (nunca use contas reais).
TENANT_A_EMAIL=
TENANT_A_PASSWORD=
TENANT_A_ID=
TENANT_B_EMAIL=
TENANT_B_PASSWORD=
TENANT_B_ID=
REQUIRE_TENANT_ISOLATION_TESTS=0

# Preview e perfis dedicados de homologacao (nunca use credenciais pessoais).
E2E_BASE_URL=
E2E_EMAIL=
E2E_PASSWORD=
E2E_COMMON_EMAIL=
E2E_COMMON_PASSWORD=
E2E_MANAGER_EMAIL=
E2E_MANAGER_PASSWORD=

# Edge function rate limits
CHAT_RATE_WINDOW_MS=60000
CHAT_RATE_MAX_REQUESTS=12

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Luna shadow runtime (read-only; no extra agenda/stock/database calls)
LUNA_SHADOW_ENABLED=false
LUNA_SHADOW_DOMAINS=bath
LUNA_SHADOW_SAMPLE_RATE=1

# Luna agent runtime budgets (optional; safe defaults are applied by the backend)
LUNA_RUNTIME_MAX_DURATION_MS=105000
LUNA_RUNTIME_MAX_TOOL_CALLS=10
LUNA_RUNTIME_MAX_TOKENS=16000
LUNA_RUNTIME_MAX_STEPS=7
LUNA_RUNTIME_MAX_VALIDATION_RETRIES=2
LUNA_TOOL_DEFAULT_TIMEOUT_MS=30000
LUNA_CONFIRMATION_TIMEOUT_MS=90000
# Set only when you have an approved blended model cost; 0 disables monetary estimates.
LUNA_ESTIMATED_COST_PER_MILLION_TOKENS=0
