{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 30
    },
    "api/admin/users.ts": {
      "maxDuration": 30
    },
    "api/admin/users/[userId].ts": {
      "maxDuration": 30
    },
    "api/admin/users/[userId]/status.ts": {
      "maxDuration": 30
    },
    "api/admin/maintenance/[action].ts": {
      "maxDuration": 30
    },
    "api/chat/respond.ts": {
      "maxDuration": 30
    },
    "api/chat/human-message.ts": {
      "maxDuration": 30
    },
    "api/fiscal/sales/[saleId]/issue.ts": {
      "maxDuration": 30
    },
    "api/fiscal/webhooks/focus.ts": {
      "maxDuration": 30
    },
    "api/products/image-suggestions.ts": {
      "maxDuration": 20
    },
    "api/petshop/checkout.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/whatsapp/webhook",
      "destination": "/api/webhook"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
