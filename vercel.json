{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 30
    },
    "api/whatsapp/webhook.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/whatsapp/webhook",
      "destination": "/api/webhook"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
