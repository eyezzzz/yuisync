{
  "name": "yuisync",
  "version": "1.0.0",
  "description": "CRM completo - Supabase + OpenAI + React",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-vite.mjs",
    "api": "node server/index.js",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "audit": "npm audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:petbot": "node --test test/petbotAgent.test.mjs test/petbotAgentV3.test.mjs test/petbotFlowMatrix.test.mjs test/petbotModes.test.mjs test/petbotSemantics.test.mjs test/petbotStatic.test.mjs",
    "test:transactions": "node --test test/transactionalStatic.test.mjs",
    "test:e2e": "playwright test",
    "test:tenant": "node scripts/test-tenant-isolation.mjs",
    "test:all": "npm run typecheck && npm run test && npm run test:petbot && npm run test:luna && npm run test:transactions && npm run build",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "test:petbot:legacy": "node --test test/petbotGuard.test.mjs",
    "test:petbot:live": "node scripts/eval-petbot-agent.mjs",
    "test:petbot:live-chat": "node --env-file=.env scripts/test-petbot-live-conversations.mjs --run",
    "test:petbot:matrix": "node --test test/petbotFlowMatrix.test.mjs",
    "test:luna:unit": "node --test test/luna/*.test.mjs",
    "test:luna:regressions": "node scripts/run-luna-scenarios.mjs",
    "test:luna": "npm run test:luna:unit && npm run test:luna:regressions"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.383.0",
    "luxon": "^3.7.2",
    "papaparse": "^5.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "read-excel-file": "^9.3.3",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "main": "postcss.config.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "22.x"
  }
}
